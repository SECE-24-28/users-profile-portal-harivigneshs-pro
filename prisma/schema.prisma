// prisma/schema.prisma
// This file defines the database models for the Voters Profile Portal.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── USER MODEL ──────────────────────────────────────────────────────────────
// Stores admin/user accounts that can log in and manage voter data.
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // Stored as bcrypt hash — NEVER plain text
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  @@map("users")
}

// ─── VOTER MODEL ─────────────────────────────────────────────────────────────
// Stores the registered voter profiles managed by authenticated users.
model Voter {
  id              String   @id @default(cuid())
  fullName        String
  age             Int
  voterIdNumber   String   @unique
  region          String
  profileImageUrl String?  // Optional: URL path to uploaded profile image
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("voters")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────
enum Role {
  USER
  ADMIN
}
